rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------
    // HELPER FUNCTIONS
    // --------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidString(str, maxLen) {
      return str is string && str.size() > 0 && str.size() <= maxLen;
    }

    function isValidNumber(num, min, max) {
      return num is number && num >= min && num <= max;
    }

    // --------------------------------------------------------
    // USER PROFILES
    // Users can only read/write their own profile
    // --------------------------------------------------------
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId)
        && isValidString(request.resource.data.email, 200)
        && isValidString(request.resource.data.displayName, 100);
      allow update: if isAuthenticated() && isOwner(userId)
        && request.resource.data.uid == userId; // Prevent UID modification
    }

    // --------------------------------------------------------
    // CARBON RESULTS
    // Users can only access their own results
    // --------------------------------------------------------
    match /carbonResults/{resultId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidNumber(request.resource.data.totalMonthlyCo2, 0, 100000)
        && isValidNumber(request.resource.data.totalAnnualCo2, 0, 1200000);
      allow update: if false; // Results are immutable — create new instead
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // --------------------------------------------------------
    // GOALS
    // --------------------------------------------------------
    match /goals/{goalId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.title, 200)
        && isValidNumber(request.resource.data.targetReduction, 0, 100000);
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid; // Can't change owner
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // --------------------------------------------------------
    // GREEN ACTIONS
    // --------------------------------------------------------
    match /greenActions/{actionId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.actionType, 50)
        && isValidNumber(request.resource.data.carbonSaved, 0, 10000);
      allow update: if false; // Actions are immutable
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // --------------------------------------------------------
    // CHALLENGE PARTICIPATIONS
    // --------------------------------------------------------
    match /challengeParticipations/{participationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.challengeId, 100);
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && isValidNumber(request.resource.data.progress, 0, 100);
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // --------------------------------------------------------
    // USER PROGRESS (education)
    // --------------------------------------------------------
    match /userProgress/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // --------------------------------------------------------
    // DENY ALL OTHER PATHS
    // --------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
